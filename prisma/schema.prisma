generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model usuarios {
  id        String   @id @default(uuid())
  nome      String
  email     String   @unique
  senha     String

  carrinhos carrinho[]
}

model produtos {
  id          String   @id @default(uuid())
  nome        String
  preco       Float
  imagem_url  String?
  categoria   String?

  // 🔥 NOVO
  tamanhos    String[] // ["P", "M", "G"] ou ["Único"]
  cores       String[] // ["Preto", "Branco"]

  estoque     Int

  carrinhos   carrinho[]
}

model carrinho {
  id          String @id @default(uuid())

  usuario_id  String
  produto_id  String

  quantidade  Int @default(1)

  // 🔥 NOVO
  tamanho     String?
  cor         String?

  usuarios    usuarios @relation(fields: [usuario_id], references: [id])
  produtos    produtos @relation(fields: [produto_id], references: [id])
}