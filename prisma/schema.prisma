generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model usuarios {
  id        Int        @id @default(autoincrement())
  nome      String
  email     String     @unique
  senha     String

  carrinhos carrinho[]   // 🔥 RELAÇÃO INVERSA
}

model produtos {
  id          Int        @id @default(autoincrement())
  nome        String
  preco       Float
  imagem_url  String?
  categoria   String?
  estoque     Int

  carrinhos   carrinho[] // 🔥 RELAÇÃO INVERSA
}

model carrinho {
  id          Int @id @default(autoincrement())

  usuario_id  Int
  produto_id  Int
  quantidade  Int @default(1)

  usuarios    usuarios @relation(fields: [usuario_id], references: [id])
  produtos    produtos @relation(fields: [produto_id], references: [id])
}